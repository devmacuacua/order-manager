<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence"
	version="2.1">
	<persistence-unit name="orderManagerPU"
		transaction-type="RESOURCE_LOCAL">
		<provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

		<class>pt.agap2.ordermanager.user.entity.UserEntity</class>
		<class>pt.agap2.ordermanager.item.entity.ItemEntity</class>
		<class>pt.agap2.ordermanager.stock.entity.StockMovementEntity</class>
		<class>pt.agap2.ordermanager.order.entity.OrderEntity</class>
		<class>pt.agap2.ordermanager.order.entity.OrderStockMovementEntity
		</class>

		<properties>
			<property name="javax.persistence.jdbc.driver"
				value="org.postgresql.Driver" />
			<property name="javax.persistence.jdbc.url"
				value="jdbc:postgresql://postgres:5432/order_manager" />
			<property name="javax.persistence.jdbc.user"
				value="order_manager" />
			<property name="javax.persistence.jdbc.password"
				value="Testes2026@" />

			<property name="hibernate.dialect"
				value="org.hibernate.dialect.PostgreSQLDialect" />

			<!-- Para avaliação: cria/atualiza schema automaticamente -->
			<property name="hibernate.hbm2ddl.auto" value="update" />

			<property name="hibernate.show_sql" value="false" />
			<property name="hibernate.format_sql" value="false" />
		</properties>
	</persistence-unit>
</persistence>